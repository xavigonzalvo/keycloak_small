{
  "realm": "myrealm",
  "enabled": true,
  "displayName": "My Realm",
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,

  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,

  "clients": [
    {
      "clientId": "example-app",
      "name": "Example JWT Application",
      "enabled": true,
      "publicClient": false,
      "secret": "example-app-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "https://localhost/app/*",
        "http://localhost/app/*",
        "http://localhost:5001/*",
        "*"
      ],
      "webOrigins": [
        "https://localhost",
        "http://localhost",
        "http://localhost:5001",
        "*"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "access.token.lifespan": "300"
      },
      "protocolMappers": [
        {
          "name": "example-app-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "example-app",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ],
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles"
      ]
    },
    {
      "clientId": "node-app",
      "name": "Node.js JWT Application",
      "enabled": true,
      "publicClient": false,
      "secret": "node-app-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "https://localhost/node-app/*",
        "http://localhost/node-app/*",
        "http://localhost:5002/*",
        "*"
      ],
      "webOrigins": [
        "https://localhost",
        "http://localhost",
        "http://localhost:5002",
        "*"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "access.token.lifespan": "300"
      },
      "protocolMappers": [
        {
          "name": "node-app-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "node-app",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ],
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles"
      ]
    },
    {
      "clientId": "mtls-app",
      "name": "mTLS Passwordless JWT Application",
      "enabled": true,
      "publicClient": false,
      "secret": "mtls-app-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "https://localhost/mtls-app/*",
        "http://localhost/mtls-app/*",
        "*"
      ],
      "webOrigins": [
        "https://localhost",
        "http://localhost",
        "*"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "access.token.lifespan": "300"
      },
      "authenticationFlowBindingOverrides": {
        "browser": "e1000001-0000-4000-a000-000000000001"
      },
      "protocolMappers": [
        {
          "name": "mtls-app-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "mtls-app",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ],
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles"
      ]
    }
  ],

  "users": [
    {
      "username": "testuser",
      "enabled": true,
      "email": "testuser@example.com",
      "firstName": "Test",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "testpassword",
          "temporary": false
        }
      ],
      "realmRoles": ["default-roles-myrealm"],
      "clientRoles": {
        "example-app": ["user"],
        "node-app": ["user"],
        "mtls-app": ["user"]
      }
    },
    {
      "username": "pivuser",
      "enabled": true,
      "email": "pivuser@example.com",
      "firstName": "PIV",
      "lastName": "User",
      "credentials": [],
      "realmRoles": ["default-roles-myrealm"],
      "clientRoles": {
        "mtls-app": ["user"]
      }
    }
  ],

  "roles": {
    "realm": [
      {
        "name": "app-user",
        "description": "Standard application user"
      },
      {
        "name": "app-admin",
        "description": "Application administrator"
      }
    ],
    "client": {
      "example-app": [
        {"name": "user",  "description": "Regular user of example-app"},
        {"name": "admin", "description": "Admin of example-app"}
      ],
      "node-app": [
        {"name": "user",  "description": "Regular user of node-app"},
        {"name": "admin", "description": "Admin of node-app"}
      ],
      "mtls-app": [
        {"name": "user",  "description": "Regular user of mtls-app"},
        {"name": "admin", "description": "Admin of mtls-app"}
      ]
    }
  },

  "scopeMappings": [],

  "identityProviders": [],

  "authenticationFlows": [
    {
      "id": "e1000001-0000-4000-a000-000000000001",
      "alias": "x509 browser",
      "description": "Browser flow with X.509 client certificate authentication (no password required)",
      "providerId": "basic-flow",
      "topLevel": true,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "auth-cookie",
          "authenticatorFlow": false,
          "requirement": "ALTERNATIVE",
          "priority": 10,
          "autheticatorFlow": false,
          "userSetupAllowed": false
        },
        {
          "authenticator": "auth-x509-client-username-form",
          "authenticatorFlow": false,
          "requirement": "ALTERNATIVE",
          "priority": 20,
          "autheticatorFlow": false,
          "userSetupAllowed": false,
          "authenticatorConfig": "x509-browser-config"
        },
        {
          "authenticatorFlow": true,
          "requirement": "ALTERNATIVE",
          "priority": 30,
          "autheticatorFlow": true,
          "flowAlias": "x509 browser forms",
          "userSetupAllowed": false
        }
      ]
    },
    {
      "id": "e1000001-0000-4000-a000-000000000002",
      "alias": "x509 browser forms",
      "description": "Username/password form as fallback",
      "providerId": "basic-flow",
      "topLevel": false,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "auth-username-password-form",
          "authenticatorFlow": false,
          "requirement": "REQUIRED",
          "priority": 10,
          "autheticatorFlow": false,
          "userSetupAllowed": false
        }
      ]
    }
  ],

  "authenticatorConfig": [
    {
      "id": "e1000001-0000-4000-a000-000000000003",
      "alias": "x509-browser-config",
      "config": {
        "x509-cert-auth.canonical-dn-enabled": "false",
        "x509-cert-auth.serialnumber-hex-enabled": "false",
        "x509-cert-auth.ocsp-checking-enabled": "",
        "x509-cert-auth.crl-checking-enabled": "",
        "x509-cert-auth.keyusage": "",
        "x509-cert-auth.extendedkeyusage": "",
        "x509-cert-auth.confirmation-page-disallowed": "",
        "x509-cert-auth.mapper-selection.user-attribute-name": "usercertificate",
        "x509-cert-auth.mapping-source-selection": "Subject's Common Name",
        "x509-cert-auth.regular-expression": "(.*)",
        "x509-cert-auth.mapper-selection": "Username or Email",
        "x509-cert-auth.timestamp-validation-enabled": "true",
        "x509-cert-auth.certificate-policy-mode": "All",
        "x509-cert-auth.certificate-policy": ""
      }
    }
  ],

  "browserFlow": "browser",
  "registrationFlow": "registration",
  "directGrantFlow": "direct grant",
  "resetCredentialsFlow": "reset credentials",
  "clientAuthenticationFlow": "clients"
}
